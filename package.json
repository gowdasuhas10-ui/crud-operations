{
  "name": "supabase-flask-crud",
  "version": "1.0.0",
  "type": "module",
  "description": "Full-stack CRUD app with Flask and Supabase",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && python app.py",
    "dev:frontend": "vite",
    "build": "vite build",
    "start": "gunicorn backend.app:app"
  },
  "devDependencies": {
    "vite": "^5.0.0",
    "concurrently": "^8.2.2"
  }
}
